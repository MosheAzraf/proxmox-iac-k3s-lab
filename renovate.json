{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["argocd"],
  "prConcurrentLimit": 1,
  "branchConcurrentLimit": 1,
  "prHourlyLimit": 1,
  "argocd": {
    "managerFilePatterns": [
      "/_kubernetes/applications/.+/app\\.yaml$/"
    ]
  }
}